{
  "name": "metaverse",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build-http": "npm i && npm run db:generate && cd apps/http && npm run build",
    "build-ws": "npm i && npm run db:generate && cd apps/ws && npm run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "npx prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --name init --schema packages/db/prisma/schema.prisma",
    "db:seed": "npx tsx packages/db/prisma/seed.ts",
    "start:http": "cd apps/http && npm run dev",
    "start:ws": "cd apps/ws && npm run dev",
    "start:frontend": "cd apps/frontend && npm run dev"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "turbo": "^2.5.3",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
