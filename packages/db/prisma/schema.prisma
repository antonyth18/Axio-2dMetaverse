generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}
// generator client {
//   provider      = "prisma-client-js"
//  binaryTargets = ["native", "linux-musl"]
// }



datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model User {
  id       String  @id @unique @default(cuid())
  username String  @unique
  password String 
  displayName String @default("")
  profileImage String @default("")
  avatarId String?
  role     Role
  spaces   Space[]
  avatar  Avatar? @relation(fields: [avatarId], references: [id])
}


model Space {
  id        String          @id @unique @default(cuid())
  name      String
  width     Int
  height    Int?
  thumbnail String?
  backgroundUrl String?
  creatorId String
  creator   User            @relation(fields: [creatorId], references: [id])
  elements  spaceElements[]
}


model spaceElements {
  id        String  @id @unique @default(cuid())
  elementId String
  spaceId   String
  x         Int
  y         Int
  height    String @default("")
  width     String @default("")
  space     Space   @relation(fields: [spaceId], references: [id])
  mapElement   Element @relation(fields: [elementId], references: [id])
}

model Element {
  id       String          @id @unique @default(cuid())
  width    Int
  height   Int
  imageUrl String
  static   Boolean 
  spaces   spaceElements[]
  map      mapElements[]
}
model background {
  id       String          @id @unique @default(cuid())
  Url      String
  maps     Map[]
}

model Map {
  id       String        @id @unique @default(cuid())
  width    Int
  height   Int
  name     String
  thumbnail String
  backgroundId String?
  background background? @relation(fields: [backgroundId], references: [id])
  elements mapElements[]
}

model mapElements {
  id        String  @id @unique @default(cuid())
  mapId     String
  elementId String
  height    String @default("")
  width     String @default("")
  x         Int?
  y         Int?
  map       Map     @relation(fields: [mapId], references: [id])
  element   Element @relation(fields: [elementId], references: [id])
}

model Avatar {
  id            String   @id @unique @default(cuid())
  Idle_downUrl  String
  Idle_leftUrl  String
  Idle_rightUrl String
  Idle_upUrl    String
  Run_downUrl   String
  Run_leftUrl   String
  Run_rightUrl  String
  Run_upUrl     String
  name          String?
  user          User[]
}

enum Role {
  Admin
  User
}
